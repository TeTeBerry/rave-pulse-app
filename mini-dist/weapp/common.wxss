:root{--rp-bg:#f8f9fc;--rp-card:#fff;--rp-text-primary:#333644;--rp-text-secondary:#8a8f9e;--rp-divider:#e9ebf2;--rp-purple:#c8b6ff;--rp-blue:#bde0fe;--background:#f8f9fc;--foreground:#333644;--shadow-x:0rpx;--shadow-y:4rpx;--shadow-blur:16rpx;--shadow-spread:0rpx;--shadow-color:rgba(200,182,255,.15)}body,html{background-color:var(--rp-bg);color:var(--foreground);margin:0;padding:0}.shadow-custom{box-shadow:var(--shadow-x) var(--shadow-y) var(--shadow-blur) var(--shadow-spread) var(--shadow-color)}.rp-gradient-bg{background:linear-gradient(135deg,var(--rp-purple) 0,var(--rp-blue) 100%)}.rp-card-shadow{box-shadow:0 4rpx 16rpx rgba(200,182,255,.15)}@keyframes wave-float{0%,100%{transform:translateY(0rpx) scaleY(1)}50%{transform:translateY(-6rpx) scaleY(.96)}}@keyframes wave-float-delay{0%,100%{transform:translateY(0rpx) scaleY(.97)}50%{transform:translateY(-4rpx) scaleY(1.03)}}@keyframes wave-float-slow{0%,100%{transform:translateY(0rpx)}50%{transform:translateY(-8rpx)}}@keyframes btn-shimmer{0%{background-position:0 50%}50%{background-position:100% 50%}100%{background-position:0 50%}}.wave-anim-1{animation:wave-float 4s ease-in-out infinite}.wave-anim-2{animation:wave-float-delay 5s ease-in-out infinite}.wave-anim-3{animation:wave-float-slow 6s ease-in-out infinite}.rp-btn-shimmer{animation:btn-shimmer 4s ease infinite;background:linear-gradient(135deg,#c8b6ff,#bde0fe 50%,#c8b6ff);background-size:200% 200%}.rp-feature-card:active{box-shadow:0 8rpx 28rpx rgba(200,182,255,.28);transform:translateY(-2rpx)}.dot-bounce-dot{animation-duration:1.2s;animation-iteration-count:infinite;animation-name:dot-bounce;animation-timing-function:ease-in-out;background-color:#7c3aed;border-radius:2rpx;height:4rpx;width:4rpx}.dot-delay-1{animation-delay:0s}.dot-delay-2{animation-delay:.2s}.dot-delay-3{animation-delay:.4s}@keyframes dot-bounce{0%,100%,80%{opacity:.5;transform:translateY(0rpx)}40%{opacity:1;transform:translateY(-8rpx)}}@keyframes mini-cover-spin{from{transform:rotate(0deg)}to{transform:rotate(1turn)}}@keyframes cover-bar-1{0%,100%{opacity:.85;transform:scaleY(1)}50%{opacity:1;transform:scaleY(.6)}}@keyframes cover-bar-2{0%,100%{opacity:.9;transform:scaleY(.72)}50%{opacity:.75;transform:scaleY(1.05)}}@keyframes cover-bar-3{0%,100%{opacity:.8;transform:scaleY(.92)}50%{opacity:1;transform:scaleY(.52)}}.cover-bar-anim-1{animation:cover-bar-1 1s ease-in-out infinite;transform-origin:center}.cover-bar-anim-2{animation:cover-bar-2 1s ease-in-out .12s infinite;transform-origin:center}.cover-bar-anim-3{animation:cover-bar-3 1s ease-in-out .24s infinite;transform-origin:center}.spin-mini-cover{animation:mini-cover-spin 8s linear infinite}